{
  "name": "sunnysideup/userforms-webhook",
  "description": "Sends the submission of a userdefined form (userform) to a webhook",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "webhook",
    "web hook",
    "userforms",
    "user defined forms",
    "userdefinedforms",
    "api",
    "connection"
  ],
  "license": "BSD-3-Clause",
  "require": {
    "silverstripe/framework": "^5.0",
    "silverstripe/admin": "^2.0"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "dev-master",
    "silverleague/ideannotator": "*",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7",
    "silverstripe/standards": "^1",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Sunnysideup\\UserformsWebhook\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "client/dist"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "bin": [
    "bin/aske-npm-build-userforms-webhook.sh",
    "bin/sake-npm-watch-userforms-webhook.sh"
  ],
  "authors": [
    {
      "name": "Nicolaas Thiemen Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ]
}
